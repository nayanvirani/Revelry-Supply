{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

{%- endstyle -%}
 {% if product.metafields.custom.bottom_images != blank %}
  <div class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}">
    <div class="{% if section.settings.full_width == true %}page-width-full{% else %}page-width{% endif %}">
      <div class="nv-bottom-images-wrapper">
          {%- for image in product.metafields.custom.bottom_images.value -%}
            <div class="image-wrpper">
                    {{ image | image_url: width: '1024x' | image_tag:loading:'lazy',alt:image.alt }}
              </div>
          {% endfor %}
          
        </div>
    </div>
  </div>
   {% endif %}
{% schema %}
{
  "name": "NV:PDP bottom images",
  "class": "section custom-nv-pdp-bottom-images",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "default":true,
      "id": "full_width",
      "label": "Full width?"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  
  "presets": [
    {
      "name": "NV:PDP bottom images",
    }
  ]
}
{% endschema %}