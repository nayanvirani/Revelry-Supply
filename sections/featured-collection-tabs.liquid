{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{% if section.blocks.first.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- for block in section.blocks -%}
  {%- unless block.settings.quick_add == 'none' -%}
    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- endunless -%}
  {%- if block.settings.quick_add == 'standard' -%}
    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {%- if block.settings.quick_add == 'bulk' -%}
    <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  {% if section.settings.background_image != blank %}
    .section-{{ section.id }}-background {
      background-image: url('{{ section.settings.background_image | image_url }}');
      background-repeat: no-repeat;
      background-size: cover;
    }
  {% endif %}
  .section-{{ section.id }}-padding .tabs-featured-collection__main-title {
    margin-top:0;
  {% if section.settings.heading_color != blank %}
  
      color: {{ section.settings.heading_color }};
    
  {% endif %}
}
  @media screen and (min-width: 750px) {
   
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
   .section-{{ section.id }}-padding .tabs-featured-collection__header{
        margin-bottom:6rem;
    }
  }

  /* ---- Tab Styles ---- */
  

 
  .section-{{ section.id }}-padding .tabs-featured-collection__tab-btn {
    text-transform: {{ section.settings.tab_text_transform }};
  }

.section-{{ section.id }}-padding .card .button.button--primary{
        --color-button: {{ section.settings.color_scheme.settings.button.red }},{{ section.settings.color_scheme.settings.button.green }},{{ section.settings.color_scheme.settings.button.blue }};
        --color-button-text: {{ section.settings.color_scheme.settings.button_label.red }},{{ section.settings.color_scheme.settings.button_label.green }},{{ section.settings.color_scheme.settings.button_label.blue }};
  }
  @media(max-width:749px){
    {% if section.settings.m_background_image != blank %}
        .section-{{ section.id }}-background{
        background-image:url('{{ section.settings.m_background_image | image_url }}');
        background-repeat: no-repeat;
        background-size: cover;
        }
    {% endif %}
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient section-{{ section.id }}-background">
  <div
    class="section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %}"
    id="collection-tabs-{{ section.id }}"
    data-id="{{ section.id }}"
  >
    {%- if section.settings.title != blank -%}
      <div class="page-width tabs-featured-collection__header{% if section.settings.heading_center %} center{% endif %}">
        <h2 class="tabs-featured-collection__main-title title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- comment -%} Tab buttons {%- endcomment -%}
       <div class="page-width">
        <div class="main-tabs-wrapper-tab">
      <div class="tabs-featured-collection__tabs-wrapper" role="tablist" aria-label="{{ section.settings.title | escape }}">
        {%- for block in section.blocks -%}
          <label
            id="tab-btn-{{ section.id }}-{{ block.id }}"
            class="tabs-featured-collection__tab-btn button button--secondary"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="tab-panel-{{ section.id }}-{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.tab_icon != blank %}
                <img src="{{block.settings.tab_icon | image_url}}" width="{{block.settings.tab_icon.width}}" height="{{block.settings.tab_icon.height}}" loading="lazy">
            {% endif %}
            {{ block.settings.tab_label }}
        </label>
        {%- endfor -%}
      </div>
    </div>
        </div>

      {%- comment -%} Tab panels {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- liquid
          assign products_to_display = block.settings.collection.all_products_count
          if block.settings.collection.all_products_count > block.settings.products_to_show
            assign products_to_display = block.settings.products_to_show
            assign more_in_collection = true
          else
            assign more_in_collection = false
          endif

          assign columns_mobile_int = block.settings.columns_mobile | plus: 0
          assign columns_desktop_int = block.settings.columns_desktop | plus: 0

          assign show_mobile_slider = false
          if block.settings.swipe_on_mobile and products_to_display > columns_mobile_int
            assign show_mobile_slider = true
          endif

          assign max_columns_to_show = columns_mobile_int
          if columns_desktop_int > columns_mobile_int
            assign max_columns_to_show = columns_desktop_int
          endif

          assign show_desktop_slider = false
          if block.settings.enable_desktop_slider and products_to_display > block.settings.columns_desktop
            assign show_desktop_slider = true
          endif
        -%}

        <div
          id="tab-panel-{{ section.id }}-{{ block.id }}"
          class="tabs-featured-collection__tab-panel{% if forloop.first %} is-active{% endif %}"
          role="tabpanel"
          aria-labelledby="tab-btn-{{ section.id }}-{{ block.id }}"
        >
          {%- if block.settings.description != blank or block.settings.show_description and block.settings.collection.description != empty -%}
            <div class="page-width">
              <div class="collection__description {{ block.settings.description_style }} rte">
                {%- if block.settings.show_description -%}
                  {{ block.settings.collection.description }}
                {%- else -%}
                  {{ block.settings.description }}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}">
            <ul
              id="Slider-{{ section.id }}-{{ block.id }}"
              data-id="{{ section.id }}"
              class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ block.settings.columns_desktop }}-col-desktop{% if block.settings.collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ block.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
              role="list"
              aria-label="{{ 'general.slider.name' | t }}"
            >
              {% assign skip_card_product_styles = false %}

              {%- if block.settings.collection.products.size > 0 -%}
                {% assign lazy_load = false %}
                {% paginate block.settings.collection.products by block.settings.products_to_show %}
                  {%- for product in block.settings.collection.products limit: block.settings.products_to_show -%}
                    {% if lazy_load == false and forloop.index > max_columns_to_show %}
                      {% assign lazy_load = true %}
                    {% endif %}
                    <li
                      id="Slide-{{ section.id }}-{{ block.id }}-{{ forloop.index }}"
                      class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      {% render 'card-product',
                        card_product: product,
                        media_aspect_ratio: block.settings.image_ratio,
                        image_shape: block.settings.image_shape,
                        lazy_load: lazy_load,
                        show_secondary_image: block.settings.show_secondary_image,
                        show_vendor: block.settings.show_vendor,
                        show_rating: block.settings.show_rating,
                        skip_styles: skip_card_product_styles,
                        section_id: section.id,
                        quick_add: block.settings.quick_add,
                        enable_images_slider:block.settings.enable_images_slider
                      %}
                    </li>
                    {%- assign skip_card_product_styles = true -%}
                  {%- endfor -%}
                {% endpaginate %}
              {%- else -%}
                {%- for i in (1..block.settings.columns_desktop) -%}
                  <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                    {%- assign ridx = forloop.rindex -%}
                    {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                    {% render 'card-product',
                      show_vendor: block.settings.show_vendor,
                      media_aspect_ratio: block.settings.image_ratio,
                      image_shape: block.settings.image_shape,
                      lazy_load: false,
                      placeholder_image: placeholder_image
                    %}
                  </li>
                {%- endfor -%}
              {%- endif -%}
            </ul>

            {%- if show_mobile_slider or show_desktop_slider -%}
              <div class="slider-buttons">
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                  aria-controls="Slider-{{ section.id }}-{{ block.id }}"
                >
                  <span class="svg-wrapper">
                    {{- 'nv-icon-arrow-prev.svg' | inline_asset_content -}}
                  </span>
                </button>
                <div class="slider-counter caption hidden">
                  <span class="slider-counter--current">1</span>
                  <span aria-hidden="true"> / </span>
                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                  <span class="slider-counter--total">{{ products_to_display }}</span>
                </div>
                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                  aria-controls="Slider-{{ section.id }}-{{ block.id }}"
                >
                  <span class="svg-wrapper">
                    {{- 'nv-icon-arrow-next.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
            {%- endif -%}
          </slider-component>

          {%- if block.settings.show_view_all and more_in_collection -%}
            <div class="center collection__view-all">
              <a
                href="{{ block.settings.collection.url }}"
                class="{% if block.settings.view_all_style == 'link' %}link underlined-link{% elsif block.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
                aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: block.settings.collection.title | escape }}"
              >
                {{ 'sections.featured_collection.view_all' | t }}
              </a>
            </div>
          {%- endif -%}

          {% if block.settings.image_shape == 'arch' %}
            {{ 'mask-arch.svg' | inline_asset_content }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    var sectionEl = document.getElementById('collection-tabs-{{ section.id }}');
    if (!sectionEl) return;

    var buttons = sectionEl.querySelectorAll('[role="tab"]');
    var panels = sectionEl.querySelectorAll('[role="tabpanel"]');

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var targetId = btn.getAttribute('aria-controls');

        // Update buttons
        buttons.forEach(function(b) {
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        });

        // Update panels
        panels.forEach(function(panel) {
          if (panel.id === targetId) {
            panel.classList.add('is-active');
          } else {
            panel.classList.remove('is-active');
          }
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Featured Collection Tabs",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Featured Collections",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" },
        { "value": "hxxl", "label": "XX Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "checkbox",
      "id": "heading_center",
      "label": "Center heading & tabs?",
      "default": false
    },
    {
      "type": "select",
      "id": "tab_text_transform",
      "label": "Tab label text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "m_background_image",
      "label": "Background image (mobile)"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "header",
          "content": "Tab settings"
        },
        {
            "type": "image_picker",
            "id": "tab_icon",
            "label": "Tab Icon"
        },
        {
          "type": "text",
          "id": "tab_label",
          "default": "Collection Tab",
          "label": "Tab label"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "range",
          "id": "products_to_show",
          "min": 2,
          "max": 25,
          "step": 1,
          "default": 4,
          "label": "Products to show"
        },
        {
          "type": "header",
          "content": "Description"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show collection description instead",
          "default": false
        },
        {
          "type": "select",
          "id": "description_style",
          "label": "Description style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "subtitle", "label": "Subtitle" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "body"
        },
        {
          "type": "header",
          "content": "Grid layout"
        },
        {
          "type": "range",
          "id": "columns_desktop",
          "min": 1,
          "max": 6,
          "step": 1,
          "default": 4,
          "label": "Columns on desktop"
        },
        {
          "type": "checkbox",
          "id": "enable_desktop_slider",
          "label": "Enable desktop slider",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_view_all",
          "default": true,
          "label": "Show 'View all' button"
        },
        {
          "type": "select",
          "id": "view_all_style",
          "label": "View all style",
          "options": [
            { "value": "link", "label": "Link" },
            { "value": "outline", "label": "Outline button" },
            { "value": "solid", "label": "Solid button" }
          ],
          "default": "solid"
        },
        {
          "type": "header",
          "content": "Product cards"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "options": [
            { "value": "adapt", "label": "Adapt to image" },
            { "value": "portrait", "label": "Portrait" },
            { "value": "square", "label": "Square" }
          ],
          "default": "adapt",
          "label": "Image ratio"
        },
        {
          "type": "select",
          "id": "image_shape",
          "options": [
            { "value": "default", "label": "Default" },
            { "value": "arch", "label": "Arch" },
            { "value": "blob", "label": "Blob" },
            { "value": "chevronleft", "label": "Chevron left" },
            { "value": "chevronright", "label": "Chevron right" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "parallelogram", "label": "Parallelogram" },
            { "value": "round", "label": "Round" }
          ],
          "default": "default",
          "label": "Image shape"
        },
        {
          "type": "checkbox",
          "id": "show_secondary_image",
          "default": false,
          "label": "Show secondary image on hover"
        },
        {
          "type": "checkbox",
          "id": "show_vendor",
          "default": false,
          "label": "Show vendor"
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "default": false,
          "label": "Show product rating",
          "info": "To display a rating, add a product rating app to your store."
        },
        {
          "type": "select",
          "id": "quick_add",
          "default": "none",
          "label": "Quick add",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "standard", "label": "Standard" },
            { "value": "bulk", "label": "Bulk" }
          ]
        },
        {
            "type": "checkbox",
            "id": "enable_images_slider",
            "label": "Enable images slider",
            "default":false
        },
        {
          "type": "header",
          "content": "Mobile"
        },
        {
          "type": "select",
          "id": "columns_mobile",
          "default": "2",
          "label": "Columns on mobile",
          "options": [
            { "value": "1", "label": "1 column" },
            { "value": "2", "label": "2 columns" }
          ]
        },
        {
          "type": "checkbox",
          "id": "swipe_on_mobile",
          "default": false,
          "label": "Enable swipe on mobile"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_label": "Tab 1"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_label": "Tab 2"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_label": "Tab 3"
          }
        }
      ]
    }
  ]
}
{% endschema %}
