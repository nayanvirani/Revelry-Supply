{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
.eg-logos {
    width: calc(100% - 2*1.5rem);
    overflow: hidden;
    /*background-color: white;*/
    overflow-x: auto;
    overscroll-behavior-x: contain;
    margin-left: auto;
    margin-right: auto;
    padding: 6px 0 ;
    margin-bottom: 0 ;
     z-index: 1;
    position: relative;
}

.eg-logos .story-card a {
    display: flex ;
    justify-content: flex-start;
    align-items: center;
    text-decoration: none;
    cursor: pointer ;
    color:rgba(var(--color-foreground), 1);
}

.eg-logos img {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    min-width: 50px;
    max-width: 50px;
    margin-right: 10px;
    display: block;
    /*scale: 1.2;*/
}

.eg-logos span {
    color: rgba(var(--color-foreground), 1);
    font-weight: 500 ;
    font-size: 14px;
    line-height: 16px;
    letter-spacing: 0 ;
    text-align:left;
     max-width:200px;
}

.eg-logos .story-wrapper {
    display: flex;
    grid-gap: 20px;
    margin-left: auto;
    margin-right: auto;
    width: max-content;
}

.eg-logos .story-card {
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 5px;
    min-width: max-content;
}

html body .story-card:not(.eg-active) {
    opacity: 0.7;
}
html body .eg-logos::-webkit-scrollbar {
    display: none;
}

html body .eg-tabs-nav__position {
    position: absolute;
    bottom: -1px;
    height: 4px;
    width: var(--width);
    background:rgba(var(--color-foreground), 1);
    transform-origin: left;
    transition: width 0.1s ease-in-out, translate 0.25s ease-in-out;
    translate: var(--prevWidth);
}

html body .eg-logos .story-card {
    margin-bottom: 0;
    padding-bottom: 12px;
}
html body .eg-logos .story-wrapper {
    box-shadow: 0 -2px #f5f5f5 inset;
    position: relative;
}
@media only screen and (min-width: 767px) {
    .section-{{ section.id }}-padding .eg-logos {
        display: flex;
        align-items: center;
        padding-bottom: 15px;
    }

}

{%- endstyle -%}
 {% if section.settings.collections != blank %}
  <div class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}">
    <div class="{% if section.settings.full_width == true %}page-width-full{% else %}page-width{% endif %}">
      <div class="eg-logos">
        <div class="story-wrapper">
          {%- for scollection in section.settings.collections -%}
            <div class="story-card{% if collection.id == scollection.id %} eg-active{% endif %}">
                <a class="logo-container" href="{{ scollection.url }}">
                  {% if scollection.metafields.custom.menu_image != blank %}
                    {% assign alt_text = scollection.metafields.custom.menu_image.alt | default:scollection.title | escape %}
                    {{ scollection.metafields.custom.menu_image | image_url: width: '200x' | image_tag:loading:'lazy',alt:alt_text }}
                  {% elsif scollection.featured_image %}
                     {% assign alt_text = scollection.featured_image.alt | default:scollection.title | escape %}
                      {{ scollection.featured_image | image_url: width: '200x' | image_tag:loading:'lazy',alt:alt_text }}
                  {% endif %}
                  <span>{{ scollection.title }}</span>
                </a>
            </div>
          {% endfor %}
          <span class="eg-tabs-nav__position" style=" --translate: 0;--width: 177px;"></span>
        </div>
      </div>
    </div>
  </div>
   {% endif %}
{% schema %}
{
  "name": "NV: Collection Swatches",
  "class": "section custom-nv-collection-swatches",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections"
    },
    {
      "type": "checkbox",
      "default":true,
      "id": "full_width",
      "label": "Full width?"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    
  ],
  "presets": [
    {
      "name": "NV:Collection Swatches",
    }
  ]
}
{% endschema %}